# Required
GLITCHTIP_ORG=your-org-slug
GLITCHTIP_TOKEN=your-glitchtip-api-token
JIRA_MCP_URL=https://your-mcp-atlassian.example.com
JIRA_PROJECT_KEY=YOUR_PROJECT
BOT_INSTANCE_ID=your-bot-instance-id

# Optional: override GlitchTip URL (default: https://glitchtip.devshift.net)
# GLITCHTIP_URL=https://glitchtip.devshift.net

# Comma-separated list of GlitchTip project names/slugs to monitor.
# Leave empty to process all projects in the organization.
GLITCHTIP_PROJECTS=your-project-prod,your-project-stage

# Optional: limit tickets created per run (0 = unlimited)
# MAX_TICKETS=0

# Optional: preview mode (no Jira tickets created)
# DRY_RUN=1
